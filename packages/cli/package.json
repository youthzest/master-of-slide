{
  "name": "@open-slide/cli",
  "version": "1.0.2",
  "description": "Scaffold an open-slide workspace with Claude Code skills preconfigured.",
  "type": "module",
  "bin": {
    "open-slide": "dist/cli.js"
  },
  "files": [
    "dist",
    "template",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "sync:template-skills": "node scripts/sync-template-skills.mjs",
    "prepack": "pnpm sync:template-skills && pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "slides",
    "presentation",
    "claude-code",
    "scaffold"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1weiho/open-slide.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/prompts": "^2.4.9",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
