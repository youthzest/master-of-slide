{
  "name": "@open-slide/core",
  "version": "1.0.2",
  "description": "Runtime and CLI for Master Of Slide, based on open-slide with Korean, PPTX, Canva, and agent workflows.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./env": {
      "types": "./env.d.ts"
    }
  },
  "bin": {
    "open-slide": "./bin.js"
  },
  "files": [
    "bin.js",
    "dist",
    "env.d.ts",
    "src/app",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "slides",
    "presentation",
    "react",
    "vite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reallygood83/master-of-slide.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.3.3",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "emoji-picker-react": "^4.18.0",
    "fast-glob": "^3.3.2",
    "fflate": "^0.8.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "pptxgenjs": "^4.0.1",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
